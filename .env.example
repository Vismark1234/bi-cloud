# dbt / Snowflake
DBT_TARGET=dev
DBT_SNOWFLAKE_ACCOUNT=TU_ACCOUNT_SNOWFLAKE
DBT_SNOWFLAKE_USER=TU_USUARIO_SNOWFLAKE
DBT_SNOWFLAKE_PASSWORD=CAMBIAR_POR_PASSWORD_REAL
DBT_SNOWFLAKE_ROLE=TU_ROLE_SNOWFLAKE
DBT_SNOWFLAKE_DATABASE=TU_DATABASE_SNOWFLAKE
DBT_SNOWFLAKE_WAREHOUSE=TU_WAREHOUSE_SNOWFLAKE
DBT_SNOWFLAKE_SCHEMA=DWH_DEV_CLOUD
DBT_SNOWFLAKE_SNAPSHOT_SCHEMA=SNAPSHOTS_DWH_CLOUD
DBT_THREADS=4

# Airbyte Cloud (opcional)
# Si tus datos raw ya estan en Snowflake, deja AIRBYTE_CONNECTION_IDS vacio
# y Dagster solo ejecutara las transformaciones dbt dentro de Snowflake.
AIRBYTE_API_BASE_URL=https://api.airbyte.com/v1
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_CONNECTION_IDS=
AIRBYTE_POLL_INTERVAL_SECONDS=10
AIRBYTE_TIMEOUT_SECONDS=3600
